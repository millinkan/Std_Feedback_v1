# Copy to .env and customise (never commit .env).

SECRET_KEY=django-insecure-dev-only-change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Logging (rotating file: logs/application.log by default; use for error analysis)
# APP_LOG_LEVEL=INFO
# APP_LOG_FILE=logs/application.log
# APP_LOG_MAX_BYTES=10485760
# APP_LOG_BACKUP_COUNT=5
# Admin log viewer (/admin/diagnostics/application-logs/): superuser-only by default
# APP_LOG_ADMIN_SUPERUSER_ONLY=True
# APP_LOG_ADMIN_MAX_LINES=5000
# APP_LOG_ADMIN_TAIL_BYTES=524288

# --- Production (set on the server, never commit real secrets) ---
# DEBUG=False
# SECRET_KEY=<50+ random chars>
# ALLOWED_HOSTS=your.domain.com,www.your.domain.com
# CSRF_TRUSTED_ORIGINS=https://your.domain.com,https://www.your.domain.com
# USE_POSTGRES=True
# POSTGRES_DB=chess_club
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
# Behind HTTPS reverse proxy:
# SECURE_SSL_REDIRECT=True
# USE_X_FORWARDED_PROTO=True
# USE_X_FORWARDED_HOST=True
# Optional HSTS (only after HTTPS works end-to-end):
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=False

# Celery / Redis (required for imports + Stockfish analysis tasks)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# Stockfish on Linux server (install package or set path to binary)
# STOCKFISH_PATH=/usr/games/stockfish

# Periodic Lichess sync (Celery Beat). Set DISABLE_LICHESS_BEAT=1 to turn off.
# LICHESS_BEAT_SCHEDULE_SECONDS=3600
# DISABLE_LICHESS_BEAT=0

# OAuth registration / sign-in (django-allauth). Lichess linking stays on the dashboard.
# Production (e.g. chesmate1.duckdns.org): add to ALLOWED_HOSTS and CSRF_TRUSTED_ORIGINS, then set:
#   PUBLIC_BASE_URL=https://chesmate1.duckdns.org
# Register redirect URIs with each provider using that host, e.g.
#   https://chesmate1.duckdns.org/accounts/google/login/callback/
#   https://chesmate1.duckdns.org/accounts/github/login/callback/
#   https://chesmate1.duckdns.org/accounts/microsoft/login/callback/
# Local dev examples:
#   http://127.0.0.1:8000/accounts/google/login/callback/
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# Microsoft Entra (Azure AD) — register a Web app; redirect URI as above with /accounts/microsoft/login/callback/
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=
# Optional: Entra tenant id, or "common" (default), "organizations", or "consumers"
# MICROSOFT_OAUTH_TENANT=common
# PUBLIC_BASE_URL=

# Deploy steps (summary):
# 1) python manage.py migrate
# 2) python manage.py collectstatic --noinput
# 3) Run gunicorn/uvicorn (WSGI), Redis, celery worker, optionally celery beat
# 4) Mount MEDIA_ROOT for persistent member avatars
